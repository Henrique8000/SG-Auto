<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sgauto.app.controller.EstoqueController">

    <!-- Barra de KPIs + ação principal -->
    <top>
        <VBox spacing="20">
            <padding><Insets top="0" right="0" bottom="20" left="0"/></padding>

            <HBox spacing="16">
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="TOTAL DE ITENS" styleClass="card-title"/>
                    <Label fx:id="lblTotalItens" text="0" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="ESTOQUE BAIXO" styleClass="card-title"/>
                    <Label fx:id="lblEstoqueBaixo" text="0" styleClass="card-value-warning"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="VALOR EM ESTOQUE" styleClass="card-title"/>
                    <Label fx:id="lblValorEstoque" text="R\$ 0,00" styleClass="card-value-accent"/>
                </VBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="txtBusca" promptText="Buscar por código ou descrição..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cmbFiltroModelo" promptText="Todos os modelos" styleClass="search-field"/>
                <Button text="+ Nova Peça" styleClass="btn-primary" onAction="#abrirModalNovaPeca"/>
            </HBox>
        </VBox>
    </top>

    <!-- Tabela -->
    <center>
        <TableView fx:id="tabelaPecas" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colCodigo" text="Código" prefWidth="25"/>
                <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="300"/>
                <TableColumn fx:id="colModelo" text="Modelo" prefWidth="120"/>
                <TableColumn fx:id="colPrecoCusto" text="Preço Custo" prefWidth="110"/>
                <TableColumn fx:id="colPrecoVenda" text="Preço Venda" prefWidth="110"/>
                <TableColumn fx:id="colEstoque" text="Estoque" prefWidth="100"/>
                <TableColumn fx:id="colAcoes" text="Ações" prefWidth="140"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS"/>
            </columnResizePolicy>
        </TableView>
    </center>
</BorderPane>