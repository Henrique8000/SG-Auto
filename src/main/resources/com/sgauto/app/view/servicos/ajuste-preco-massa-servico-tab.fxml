<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sgauto.app.controller.servicos.AjustePrecoMassaServicoController">

    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <fx:define>
        <ToggleGroup fx:id="grupoTipoAjuste"/>
    </fx:define>

    <top>
        <VBox spacing="14">
            <padding><Insets bottom="16"/></padding>
            <Label text="Selecione os serviços e defina o ajuste de valor" styleClass="page-subtitle"/>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="txtBusca" promptText="Buscar por código ou nome..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cmbFiltroCategoria" promptText="Todas as categorias" styleClass="search-field"/>
                <CheckBox fx:id="chkSelecionarTodos" text="Selecionar todos" onAction="#alternarSelecionarTodos"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox>
            <padding><Insets top="0" bottom="16"/></padding>
            <TableView fx:id="tabela" styleClass="modern-table" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colSelecionar" prefWidth="40" sortable="false"/>
                    <TableColumn fx:id="colCodigo" text="Código" prefWidth="80"/>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="220"/>
                    <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="130"/>
                    <TableColumn fx:id="colValor" text="Valor" prefWidth="100"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <VBox styleClass="painel-ajuste">
            <HBox spacing="20">
                <VBox spacing="6">
                    <Label text="Tipo de ajuste" styleClass="form-label"/>
                    <HBox styleClass="segmented-control">
                        <ToggleButton fx:id="btnValorFixo" text="Valor Fixo (R\$)" styleClass="segmented-button" toggleGroup="$grupoTipoAjuste" selected="true"/>
                        <ToggleButton fx:id="btnPercentual" text="Percentual (%)" styleClass="segmented-button" toggleGroup="$grupoTipoAjuste"/>
                    </HBox>
                </VBox>

                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Valor do ajuste" styleClass="form-label"/>
                    <TextField fx:id="txtValor" promptText="Ex: 10 ou -5" styleClass="form-input"/>
                </VBox>
            </HBox>

            <HBox spacing="16" alignment="CENTER_LEFT">
                <padding><Insets top="16"/></padding>
                <Label fx:id="lblSelecionados" text="0 serviço(s) selecionado(s)" styleClass="selecionados-count"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblErro" styleClass="form-error" managed="false" visible="false"/>
                <Button text="Aplicar Ajuste" styleClass="btn-primary" onAction="#aplicarAjuste"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>