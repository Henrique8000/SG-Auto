<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sgauto.app.controller.servicos.CategoriaTabController">

    <fx:define>
        <ToggleGroup fx:id="grupoStatus"/>
    </fx:define>

    <top>
        <VBox spacing="16">
            <padding><Insets bottom="20"/></padding>

            <HBox spacing="16">
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="TOTAL DE CATEGORIAS" styleClass="card-title"/>
                    <Label fx:id="lblTotalCategorias" text="0" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="ATIVAS" styleClass="card-title"/>
                    <Label fx:id="lblCategoriasAtivas" text="0" styleClass="card-value-accent"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="EM USO" styleClass="card-title"/>
                    <Label fx:id="lblCategoriasEmUso" text="0" styleClass="card-value"/>
                </VBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="txtBusca" promptText="Buscar por nome..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                <Button text="+ Nova Categoria" styleClass="btn-primary" onAction="#abrirModalNovaCategoria"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <HBox styleClass="segmented-control">
                    <ToggleButton fx:id="btnStatusTodos" text="Todas" styleClass="segmented-button" toggleGroup="$grupoStatus" selected="true"/>
                    <ToggleButton fx:id="btnStatusAtivas" text="Ativas" styleClass="segmented-button" toggleGroup="$grupoStatus"/>
                    <ToggleButton fx:id="btnStatusInativas" text="Inativas" styleClass="segmented-button" toggleGroup="$grupoStatus"/>
                </HBox>

                <ComboBox fx:id="cmbFiltroTipo" promptText="Todos os tipos" styleClass="search-field"/>

                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblContagem" styleClass="results-count"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane>
            <TableView fx:id="tabelaCategorias" styleClass="modern-table">
                <columns>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="190"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="100"/>
                    <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="220"/>
                    <TableColumn fx:id="colUso" text="Uso" prefWidth="90"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="90"/>
                    <TableColumn fx:id="colAcoes" text="Ações" prefWidth="210"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS"/>
                </columnResizePolicy>
            </TableView>

            <VBox fx:id="painelVazio" alignment="CENTER" spacing="8" visible="false" managed="false">
                <Label text="🔍" styleClass="empty-state-icon"/>
                <Label text="Nenhuma categoria encontrada" styleClass="empty-state-title"/>
                <Label text="Tente ajustar os filtros ou cadastre uma nova categoria" styleClass="empty-state-subtitle"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>