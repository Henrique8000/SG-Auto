<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sgauto.app.controller.clientes.ClientesController">

    <!-- Barra de KPIs + ação principal -->
    <top>
        <VBox spacing="20">
            <padding><Insets top="0" right="0" bottom="20" left="0"/></padding>

            <HBox spacing="16">
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="TOTAL DE CLIENTES" styleClass="card-title"/>
                    <Label fx:id="lblTotalClientes" text="0" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="PESSOA FÍSICA" styleClass="card-title"/>
                    <Label fx:id="lblTotalPF" text="0" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="PESSOA JURÍDICA" styleClass="card-title"/>
                    <Label fx:id="lblTotalPJ" text="0" styleClass="card-value-accent"/>
                </VBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="txtBusca" promptText="Buscar por nome ou documento..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cmbFiltroTipo" promptText="Todos os tipos" styleClass="search-field"/>
                <Button text="+ Novo Cliente" styleClass="btn-primary" onAction="#abrirModalNovoCliente"/>
            </HBox>
        </VBox>
    </top>

    <!-- Tabela -->
    <center>
        <TableView fx:id="tabelaClientes" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colNome" text="Nome" prefWidth="240"/>
                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="70"/>
                <TableColumn fx:id="colDocumento" text="CPF/CNPJ" prefWidth="150"/>
                <TableColumn fx:id="colCelular" text="Celular" prefWidth="130"/>
                <TableColumn fx:id="colEmail" text="E-mail" prefWidth="200"/>
                <TableColumn fx:id="colAcoes" text="Ações" prefWidth="140"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS"/>
            </columnResizePolicy>
        </TableView>
    </center>
</BorderPane>