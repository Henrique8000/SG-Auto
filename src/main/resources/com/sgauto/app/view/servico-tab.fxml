<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sgauto.app.controller.ServicoTabController">

    <top>
        <VBox spacing="20">
            <padding><Insets bottom="20"/></padding>

            <HBox spacing="16">
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="TOTAL DE SERVIÇOS" styleClass="card-title"/>
                    <Label fx:id="lblTotalServicos" text="0" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="SERVIÇOS ATIVOS" styleClass="card-title"/>
                    <Label fx:id="lblServicosAtivos" text="0" styleClass="card-value-accent"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="VALOR MÉDIO" styleClass="card-title"/>
                    <Label fx:id="lblValorMedio" text="R\$ 0,00" styleClass="card-value"/>
                </VBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="txtBusca" promptText="Buscar por código ou nome..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="cmbFiltroCategoria" promptText="Todas as categorias" styleClass="search-field"/>
                <Button text="+ Novo Serviço" styleClass="btn-primary" onAction="#abrirModalNovoServico"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tabelaServicos" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="colCodigo" text="Código" prefWidth="90"/>
                <TableColumn fx:id="colNome" text="Nome" prefWidth="220"/>
                <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="130"/>
                <TableColumn fx:id="colValor" text="Valor" prefWidth="110"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                <TableColumn fx:id="colAcoes" text="Ações" prefWidth="160"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS"/>
            </columnResizePolicy>
        </TableView>
    </center>
</BorderPane>