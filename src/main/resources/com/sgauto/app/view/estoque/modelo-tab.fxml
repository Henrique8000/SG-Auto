<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sgauto.app.controller.estoque.ModeloTabController">

    <fx:define>
        <ToggleGroup fx:id="grupoStatus"/>
    </fx:define>

    <top>
        <VBox spacing="16">
            <padding><Insets bottom="20"/></padding>

            <HBox spacing="16">
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="TOTAL DE MODELOS" styleClass="card-title"/>
                    <Label fx:id="lblTotalModelos" text="0" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="ATIVOS" styleClass="card-title"/>
                    <Label fx:id="lblModelosAtivos" text="0" styleClass="card-value-accent"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="EM USO" styleClass="card-title"/>
                    <Label fx:id="lblModelosEmUso" text="0" styleClass="card-value"/>
                </VBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="txtBusca" promptText="Buscar por nome..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                <Button text="+ Novo Modelo" styleClass="btn-primary" onAction="#abrirModalNovoModelo"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <HBox styleClass="segmented-control">
                    <ToggleButton fx:id="btnStatusTodos" text="Todos" styleClass="segmented-button" toggleGroup="$grupoStatus" selected="true"/>
                    <ToggleButton fx:id="btnStatusAtivos" text="Ativos" styleClass="segmented-button" toggleGroup="$grupoStatus"/>
                    <ToggleButton fx:id="btnStatusInativos" text="Inativos" styleClass="segmented-button" toggleGroup="$grupoStatus"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblContagem" styleClass="results-count"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane>
            <TableView fx:id="tabelaModelos" styleClass="modern-table">
                <columns>
                    <TableColumn fx:id="colNome" text="Nome" prefWidth="200"/>
                    <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="260"/>
                    <TableColumn fx:id="colUso" text="Uso" prefWidth="100"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
                    <TableColumn fx:id="colAcoes" text="Ações" prefWidth="210"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS"/>
                </columnResizePolicy>
            </TableView>

            <VBox fx:id="painelVazio" alignment="CENTER" spacing="8" visible="false" managed="false">
                <Label text="🔍" styleClass="empty-state-icon"/>
                <Label text="Nenhum modelo encontrado" styleClass="empty-state-title"/>
                <Label text="Tente ajustar os filtros ou cadastre um novo modelo" styleClass="empty-state-subtitle"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>