<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sgauto.app.controller.caixa.CaixaController">

    <fx:define>
        <ToggleGroup fx:id="grupoTipo"/>
    </fx:define>

    <top>
        <VBox spacing="16">
            <padding><Insets bottom="20"/></padding>

            <Label fx:id="lblCaixaAbertoDesde" text="Caixa aberto desde: --" styleClass="page-subtitle-caixa"/>
            <Label fx:id="lblIdCaixaAtual" text="ID do caixa: --" styleClass="page-subtitle-caixa"/>

            <HBox spacing="16">
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="VALOR DE ABERTURA" styleClass="card-title"/>
                    <Label fx:id="lblValorAbertura" text="R\$ 0,00" styleClass="card-value"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="TOTAL ENTRADAS" styleClass="card-title"/>
                    <Label fx:id="lblTotalEntradas" text="R\$ 0,00" styleClass="card-value-accent"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="TOTAL SAÍDAS" styleClass="card-title"/>
                    <Label fx:id="lblTotalSaidas" text="R\$ 0,00" styleClass="card-value-warning"/>
                </VBox>
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <Label text="VALOR ESPERADO EM CAIXA" styleClass="card-title"/>
                    <Label fx:id="lblValorEsperado" text="R\$ 0,00" styleClass="card-value"/>
                </VBox>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="txtBusca" promptText="Buscar por descrição ou placa..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                <Button text="+ Nova Movimentação" styleClass="btn-secondary" onAction="#abrirModalMovimentacao"/>
                <Button text="Fechar Caixa" styleClass="btn-primary" onAction="#abrirModalFechamento"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <HBox styleClass="segmented-control">
                    <ToggleButton fx:id="btnFiltroTodos" text="Todos" styleClass="segmented-button" toggleGroup="$grupoTipo" selected="true"/>
                    <ToggleButton fx:id="btnFiltroEntrada" text="Entrada" styleClass="segmented-button" toggleGroup="$grupoTipo"/>
                    <ToggleButton fx:id="btnFiltroSaida" text="Saída" styleClass="segmented-button" toggleGroup="$grupoTipo"/>
                </HBox>

                <ComboBox fx:id="cmbFiltroOrigem" promptText="Todas as origens" styleClass="search-field"/>
                <ComboBox fx:id="cmbFiltroFormaPagamento" promptText="Todas as formas" styleClass="search-field"/>

                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblContagem" styleClass="results-count"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane>
            <TableView fx:id="tabelaMovimentacoes" styleClass="modern-table">
                <columns>
                    <TableColumn fx:id="colData" text="Data/Hora" prefWidth="140"/>
                    <TableColumn fx:id="colTipo" text="Tipo" prefWidth="90"/>
                    <TableColumn fx:id="colOrigem" text="Origem" prefWidth="130"/>
                    <TableColumn fx:id="colFormaPagamento" text="Pagamento" prefWidth="110"/>
                    <TableColumn fx:id="colValor" text="Valor" prefWidth="110"/>
                    <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="240"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY_ALL_COLUMNS"/>
                </columnResizePolicy>
            </TableView>

            <VBox fx:id="painelVazio" alignment="CENTER" spacing="8" visible="false" managed="false">
                <Label text="🔍" styleClass="empty-state-icon"/>
                <Label text="Nenhuma movimentação encontrada" styleClass="empty-state-title"/>
                <Label text="Tente ajustar os filtros de busca" styleClass="empty-state-subtitle"/>
            </VBox>
        </StackPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding><Insets top="16"/></padding>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Histórico - Fechamentos" styleClass="btn-secondary" onAction="#abrirModalHistorico"/>
        </HBox>
    </bottom>
</BorderPane>