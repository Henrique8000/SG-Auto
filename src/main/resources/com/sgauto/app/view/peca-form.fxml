<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.sgauto.app.controller.PecaFormController"
      styleClass="modal-container" spacing="16" prefWidth="420">

    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <Label fx:id="lblTituloModal" text="Nova Peça" styleClass="page-title"/>

    <VBox spacing="4">
        <Label text="Código" styleClass="form-label"/>
        <TextField fx:id="txtCodigo" styleClass="form-input"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Descrição" styleClass="form-label"/>
        <TextField fx:id="txtDescricao" styleClass="form-input"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Modelo" styleClass="form-label"/>
        <TextField fx:id="txtModelo" styleClass="form-input" promptText="Deixe em branco para usar 'Geral'"/>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Preço de Custo" styleClass="form-label"/>
            <TextField fx:id="txtPrecoCusto" styleClass="form-input"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Preço de Venda" styleClass="form-label"/>
            <TextField fx:id="txtPrecoVenda" styleClass="form-input"/>
        </VBox>
    </HBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Quantidade em Estoque" styleClass="form-label"/>
            <TextField fx:id="txtQuantidade" styleClass="form-input"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Estoque Mínimo" styleClass="form-label"/>
            <TextField fx:id="txtEstoqueMinimo" styleClass="form-input"/>
        </VBox>
    </HBox>

    <Label fx:id="lblErro" styleClass="form-error" managed="false" visible="false"/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancelar" styleClass="btn-secondary" onAction="#cancelar"/>
        <Button fx:id="btnSalvar" text="Salvar" styleClass="btn-primary" onAction="#salvar"/>
    </HBox>
</VBox>